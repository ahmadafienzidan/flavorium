# Copy this file to `.env` and fill in your real password.
# `.env` is gitignored (never committed); `.env.example` is the shared template.

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Replace <PASSWORD> with the password you set during PostgreSQL install.
DATABASE_URL="postgresql://postgres:<PASSWORD>@localhost:5432/flavorium?schema=public"
